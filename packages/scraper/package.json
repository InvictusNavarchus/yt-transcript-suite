{
	"name": "@youtube-transcript/scraper",
	"version": "1.2.0",
	"description": "Fetch transcript from a YouTube video",
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"import": "./src/index.ts",
			"types": "./src/index.ts"
		}
	},
	"scripts": {
		"build": "vite build",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit"
	},
	"author": "ericmmartin",
	"keywords": [
		"youtube",
		"transcript"
	],
	"devDependencies": {
		"@types/bun": "^1.3.10",
		"ajv": "^8.18.0",
		"entities": "^7.0.1",
		"globals": "^16.5.0",
		"https-proxy-agent": "^7.0.6",
		"i": "0.3.7",
		"nock": "^14.0.10",
		"tslib": "^2.8.1",
		"typescript": "^5.9.2",
		"typescript-eslint": "^8.50.0",
		"vite": "^7.3.1",
		"vite-plugin-dts": "^4.5.4",
		"vitest": "^4.0.18"
	},
	"files": [
		"dist/*"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/farhandigital/youtube-transcript-edge.git"
	},
	"publishConfig": {
		"access": "public"
	},
	"homepage": "https://github.com/farhandigital/youtube-transcript-edge",
	"engines": {
		"node": ">=18.0.0"
	},
	"dependencies": {
		"fast-xml-parser": "^5.4.2"
	}
}
