{
	"name": "youtube-transcript-monorepo",
	"private": true,
	"type": "module",
	"workspaces": [
		"packages/*"
	],
	"catalog": {
		"typescript": "^7.0.1-rc",
		"@types/bun": "^1.3.14",
		"@types/node": "^26.0.1"
	},
	"scripts": {
		"cli": "bun run --filter '@youtube-transcript/cli' cli",
		"inspect": "bun run --filter '@youtube-transcript/cli' inspect",
		"dev:server": "bun run --filter '@youtube-transcript/server' dev",
		"dev:userscript": "bun run --filter '@youtube-transcript/userscript' dev",
		"build:scraper": "bun run --filter '@youtube-transcript/scraper' build",
		"build:userscript": "bun run --filter '@youtube-transcript/userscript' build",
		"typecheck": "bun run --filter '*' typecheck",
		"test": "bun run --filter '@youtube-transcript/scraper' test",
		"format": "bunx @biomejs/biome format --write .",
		"lint": "bunx @biomejs/biome lint .",
		"prepare": "lefthook install"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.1",
		"@types/node": "catalog:",
		"lefthook": "^2.1.9",
		"typescript": "catalog:"
	}
}
